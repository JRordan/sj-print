# Copy to .env.local for dev. Never commit real values.
# IMPORTANT: any VITE_* var is INLINED into the public JS bundle at build
# time — they are public. Don't put secrets here. See SECURITY.md.

# Backend API base URL.
# Local dev:   http://localhost:8000
# Production:  https://api.sjprint.us
VITE_API_BASE_URL=http://localhost:8000
